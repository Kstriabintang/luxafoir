# ─── Site ───────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Supabase ───────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Database (Prisma → Supabase Postgres) ──────────
# Pooled connection for the app:
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.your-project.supabase.co:6543/postgres?pgbouncer=true"
# Direct connection for migrations:
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.your-project.supabase.co:5432/postgres"

# ─── Midtrans (Payment) ─────────────────────────────
MIDTRANS_SERVER_KEY="your-midtrans-server-key"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="your-midtrans-client-key"
# "true" for production, "false" for sandbox:
MIDTRANS_IS_PRODUCTION="false"

# ─── Resend (Email) ─────────────────────────────────
RESEND_API_KEY="re_xxxxxxxx"
RESEND_FROM_EMAIL="LUXAFOIR <studio@luxafoir.com>"
