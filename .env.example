# ─── Site ───────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Supabase ───────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Database (Prisma → Supabase Postgres) ──────────
# Pooled connection for the app:
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.your-project.supabase.co:6543/postgres?pgbouncer=true"
# Direct connection for migrations:
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.your-project.supabase.co:5432/postgres"

# ─── Pakasir (Payment) ──────────────────────────────
# Server-side only — never expose the API key to the client/repo.
# Set these in the Vercel project's Environment Variables.
PAKASIR_PROJECT="luxafoir"
PAKASIR_API_KEY="your-pakasir-api-key"
# "sandbox" shows the in-app simulate-payment button; "production" for live.
PAKASIR_MODE="sandbox"
NEXT_PUBLIC_PAKASIR_MODE="sandbox"

# ─── Resend (Email) ─────────────────────────────────
RESEND_API_KEY="re_xxxxxxxx"
RESEND_FROM_EMAIL="LUXAFOIR <studio@luxafoir.com>"
